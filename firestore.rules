rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bolos do dia - compartilhado entre todos os atendentes
    match /bolos_dia/{diaId} {
      allow read, write: if true;
    }

    // Pedidos - compartilhado (n8n cria, frontend gerencia)
    match /pedidos/{pedidoId} {
      allow read, write: if true;
    }

    // Conversas - n8n gerencia estado
    match /conversas/{conversaId} {
      allow read, write: if true;
    }

    // Clientes - dados persistentes por telefone
    match /clientes/{clienteId} {
      allow read, write: if true;
    }

    // Ingredientes - por usuario
    match /ingredientes/{ingredienteId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;

      match /historico/{historicoId} {
        allow read: if request.auth != null && resource.data.userId == request.auth.uid;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      }
    }

    // Receitas - leitura para todos autenticados, escrita por dono
    match /receitas/{receitaId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;

      match /historico/{historicoId} {
        allow read: if request.auth != null && resource.data.userId == request.auth.uid;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      }
    }
  }
}

